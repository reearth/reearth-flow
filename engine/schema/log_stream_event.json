{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LogStreamEvent",
  "type": "object",
  "required": [
    "jobId",
    "logLevel",
    "message",
    "timestamp",
    "workflowId"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "format": "uuid"
    },
    "jobId": {
      "type": "string",
      "format": "uuid"
    },
    "logLevel": {
      "type": "string"
    },
    "nodeId": {
      "type": [
        "string",
        "null"
      ]
    },
    "message": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
