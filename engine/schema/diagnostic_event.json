{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagnosticEvent",
  "description": "Construction is unconditional; publishing is gated by `ENABLE_DIAGNOSTICS`.",
  "type": "object",
  "required": [
    "category",
    "code",
    "jobId",
    "message",
    "schema",
    "severity",
    "timestamp",
    "workflowId"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "workflowId": {
      "type": "string",
      "format": "uuid"
    },
    "jobId": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "code": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "effectiveDisposition": {
      "type": [
        "string",
        "null"
      ]
    },
    "nodeId": {
      "type": [
        "string",
        "null"
      ]
    },
    "actionType": {
      "type": [
        "string",
        "null"
      ]
    },
    "featureId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "message": {
      "type": "string"
    },
    "help": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceSpan": {
      "anyOf": [
        {
          "$ref": "#/definitions/WireSourceSpan"
        },
        {
          "type": "null"
        }
      ]
    },
    "aggregated": {
      "anyOf": [
        {
          "$ref": "#/definitions/WireAggregateInfo"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "WireSourceSpan": {
      "type": "object",
      "required": [
        "offset"
      ],
      "properties": {
        "offset": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "length": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "WireAggregateInfo": {
      "type": "object",
      "required": [
        "count",
        "sampleFeatureIds"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "sampleFeatureIds": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  }
}
