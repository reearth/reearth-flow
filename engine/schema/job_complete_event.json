{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobCompleteEvent",
  "type": "object",
  "required": [
    "jobId",
    "result",
    "timestamp",
    "workflowId"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "format": "uuid"
    },
    "jobId": {
      "type": "string",
      "format": "uuid"
    },
    "result": {
      "$ref": "#/definitions/JobResult"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "failedNodes": {
      "description": "Structured per-node fatal failures (`RunSummary::failed_nodes`). Absent = no `RunSummary` was produced; empty = one was, with none recorded — never infer job failure from either. Fatality must be read from `effectiveDisposition`, not `severity` (the latter isn't rewritten when a policy promotes an entry to fatal at resolution time).",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/WireDiagnostic"
      }
    },
    "aggregatedDiagnostics": {
      "description": "finish()-time diagnostics aggregated per node (`RunSummary::aggregated_diagnostics`); never a `Fatal` entry (those surface via `failedNodes`). Same absent-vs-empty contract.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/WireDiagnostic"
      }
    },
    "droppedEventCount": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    }
  },
  "definitions": {
    "JobResult": {
      "type": "string",
      "enum": [
        "success",
        "failed"
      ]
    },
    "WireDiagnostic": {
      "description": "Wire form of `Diagnostic`. Enums are carried as `snake_case` strings rather than tagged JSON so unknown/newer values survive a Go round-trip instead of failing to deserialize.",
      "type": "object",
      "required": [
        "category",
        "code",
        "message",
        "severity"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "effectiveDisposition": {
          "type": [
            "string",
            "null"
          ]
        },
        "nodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "actionType": {
          "type": [
            "string",
            "null"
          ]
        },
        "featureId": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "message": {
          "type": "string"
        },
        "help": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceSpan": {
          "anyOf": [
            {
              "$ref": "#/definitions/WireSourceSpan"
            },
            {
              "type": "null"
            }
          ]
        },
        "aggregated": {
          "anyOf": [
            {
              "$ref": "#/definitions/WireAggregateInfo"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "WireSourceSpan": {
      "description": "Wire mirror of `reearth_flow_diagnostics::SourceSpan`.",
      "type": "object",
      "required": [
        "offset"
      ],
      "properties": {
        "offset": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "length": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "WireAggregateInfo": {
      "description": "Wire mirror of `reearth_flow_diagnostics::AggregateInfo`.",
      "type": "object",
      "required": [
        "count",
        "sampleFeatureIds"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "sampleFeatureIds": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  }
}
